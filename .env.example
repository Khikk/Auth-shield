# ──────────────────────────────────────────────
# AuthShield — переменные окружения
# Шаблон
# ──────────────────────────────────────────────

# Порт сервера
PORT=3000

# Секреты JWT — использует длинные случайные строки
# Генерация: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ЗАМЕНИТЕ_НА_ДЛИННУЮ_СЛУЧАЙНУЮ_СТРОКУ_МИНИМУМ_64_СИМВОЛА
JWT_REFRESH_SECRET=ЗАМЕНИТЕ_НА_ДРУГУЮ_ДЛИННУЮ_СЛУЧАЙНУЮ_СТРОКУ_64_СИМВОЛА

# Разрешить ли передавать роль при регистрации
ALLOW_ROLE_PARAM=false

# Окружение
NODE_ENV=development
